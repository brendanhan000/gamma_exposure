# Copy this to ".env" (which is git-ignored) and fill in your values.
# Load it into your shell before running, with:
#     set -a; source .env; set +a
#
# Schwab Trader (Market Data) API credentials — from developer.schwab.com
# The app must have the *Market Data Production* product, status "Ready For Use",
# and callback URL https://127.0.0.1:8182
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
#
# Optional overrides (defaults shown):
# SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
# SCHWAB_TOKEN_PATH=.schwab_token.json
