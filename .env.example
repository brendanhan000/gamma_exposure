# Copy this to ".env" (which is git-ignored) and fill in your values.
# Load it into your shell before running, with:
#     set -a; source .env; set +a
#
# Schwab Trader (Market Data) API credentials — from developer.schwab.com
# The app must have the *Market Data Production* product, status "Ready For Use",
# and callback URL https://127.0.0.1:8182
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
#
# Optional overrides (defaults shown):
# SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
# SCHWAB_TOKEN_PATH=.schwab_token.json
#
# --- Push-to-phone (scripts/daily_gex.sh) — set ONE notifier below ---
# Tickers + per-cadence expiration windows (defaults shown):
# GEX_TICKERS="SPY QQQ"
# GEX_DAILY_DAYS=45
# GEX_WEEKLY_DAYS=90
# GEX_MONTHLY_DAYS=150
# GEX_SEND_CHARTS=1          # set 0 for text-only (no chart images)
# Pushover (pushover.net app + tokens; sends the chart image):
# PUSHOVER_TOKEN=
# PUSHOVER_USER=
# Telegram (create a bot via @BotFather; sends the chart image):
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ntfy.sh (free, no account; install the app + subscribe to a hard-to-guess topic):
# NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh
